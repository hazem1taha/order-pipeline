{
  "name": "@order-pipeline/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend — event-driven order ingestion pipeline",
  "scripts": {
    "test:unit": "jest --config jest.config.ts --testPathPattern=tests/unit",
    "test:integration": "jest --config jest.config.ts --testPathPattern=tests/integration",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "deploy": "serverless deploy --stage dev",
    "remove": "serverless remove --stage dev"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/client-eventbridge": "^3.540.0",
    "@aws-sdk/client-sqs": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/node": "^20.11.30",
    "aws-sdk-client-mock": "^4.0.1",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "serverless": "^4.0.0",
    "serverless-esbuild": "^1.51.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.2"
  }
}
